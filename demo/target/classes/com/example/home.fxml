<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
=================================================================
HALAMAN   : HOME / EKSPLORASI DESTINASI WISATA
FILE      : home.fxml
Controller: com.example.HomeController
Kelompok  : B6

STRUKTUR:
  1. Header Bar  — Logo | Nav Menu | Profile Button
  2. Hero Section — Judul besar + Search Bar
  3. Filter Bar   — Kategori, Rating, Harga
  4. Top Destination — FlowPane berisi Destination Cards
  5. Kategori Populer — Chip kategori
  6. Footer

DATABASE INTEGRATION NOTES:
  - [DB] FlowPane (fx:id="destinationFlowPane") diisi dinamis oleh HomeController
         → SELECT id, nama, lokasi, harga, rating, gambar_url FROM destinasi
           WHERE aktif = true ORDER BY rating DESC
  - [DB] ComboBox kategoriFilter → SELECT DISTINCT kategori FROM destinasi
  - [DB] ComboBox ratingFilter    → nilai statis: 3.0, 3.5, 4.0, 4.5
  - [DB] ComboBox hargaFilter     → range: < 50K, 50-100K, 100-200K, > 200K
=================================================================
-->

<BorderPane
    prefHeight="900.0"
    prefWidth="1400.0"
    styleClass="root"
    stylesheets="@style.css"
    xmlns="http://javafx.com/javafx/19"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.HomeController">

    <!-- ============================================================
         TOP: HEADER BAR
         ============================================================ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30.0" styleClass="header-bar"
              style="-fx-padding: 12 30;">

            <!-- LOGO -->
            <VBox alignment="CENTER_LEFT" spacing="2.0">
                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #DEFF9A;"
                       text="WISATA" />
                <Label style="-fx-font-size: 9; -fx-text-fill: #DAFFDE; -fx-padding: 0 2;"
                       text="Kelompok B6" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- NAVIGATION MENU -->
            <HBox alignment="CENTER" spacing="8.0">
                <!-- [CONTROLLER] Setiap tombol Nav dihubungkan ke onAction di HomeController -->
                <Button styleClass="nav-button, active" text="Home"
                        fx:id="navHome" onAction="#handleNavHome" />
                <Button styleClass="nav-button" text="Booking Saya"
                        fx:id="navBooking" onAction="#handleNavBooking" />
                <Button styleClass="nav-button" text="Wishlist"
                        fx:id="navWishlist" onAction="#handleNavWishlist" />
                <Button styleClass="nav-button" text="Itinerary"
                        fx:id="navItinerary" onAction="#handleNavItinerary" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- PROFILE BUTTON -->
            <!-- [DB] Jika sudah login, tampilkan nama user dari sesi; jika tidak, tampilkan "Login" -->
            <Button fx:id="profileButton"
                    style="-fx-padding: 9 20; -fx-background-color: #DEFF9A;
                           -fx-text-fill: #121212; -fx-border-radius: 15;
                           -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 13;"
                    text="Login" onAction="#handleLogin" />
        </HBox>
    </top>

    <!-- ============================================================
         CENTER: MAIN CONTENT (Scrollable)
         ============================================================ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="0" style="-fx-background-color: #121212;">

                <!-- ================================================
                     HERO SECTION
                     ================================================ -->
                <VBox alignment="CENTER" spacing="18.0" styleClass="hero-section">
                    <Label
                        style="-fx-font-size: 42; -fx-font-weight: bold;
                               -fx-text-fill: #f5f5f5; -fx-alignment: center;"
                        text="Temukan destinasi liburanmu"
                        wrapText="true" />
                    <Label
                        style="-fx-font-size: 16; -fx-text-fill: #DAFFDE; -fx-alignment: center;"
                        text="Jelajahi keindahan alam &amp; budaya Indonesia bersama kami"
                        wrapText="true" />

                    <!-- SEARCH BAR -->
                    <HBox alignment="CENTER" spacing="10.0"
                          style="-fx-padding: 20 0 0 0; -fx-max-width: 760;">
                        <TextField
                            fx:id="searchField"
                            styleClass="search-field"
                            promptText="Cari destinasi, kota, atau kategori..."
                            prefWidth="580.0"
                            HBox.hgrow="ALWAYS" />
                        <!-- [CONTROLLER] onAction "#handleSearch" di HomeController -->
                        <Button
                            fx:id="searchButton"
                            style="-fx-padding: 13 30; -fx-font-size: 14; -fx-font-weight: bold;
                                   -fx-border-radius: 25; -fx-background-radius: 25;"
                            text="Cari" onAction="#handleSearch" />
                    </HBox>

                    <!-- QUICK CATEGORY CHIPS -->
                    <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10 0 0 0;">
                        <Button styleClass="category-chip" text="Pantai" />
                        <Button styleClass="category-chip" text="Pegunungan" />
                        <Button styleClass="category-chip" text="Budaya" />
                        <Button styleClass="category-chip" text="Alam" />
                        <Button styleClass="category-chip" text="Hiburan" />
                        <Button styleClass="category-chip" text="Kuliner" />
                    </HBox>
                </VBox>

                <!-- ================================================
                     FILTER BAR
                     ================================================ -->
                <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="filter-bar">
                    <Label style="-fx-font-size: 13; -fx-font-weight: bold;
                                  -fx-text-fill: #DEFF9A;"
                           text="Filter:" />

                    <!-- [DB] Isi dari query SELECT DISTINCT kategori FROM destinasi -->
                    <VBox spacing="4.0">
                        <Label styleClass="subtitle" text="Kategori Tempat" />
                        <ComboBox fx:id="kategoriFilter" prefWidth="200.0"
                                  promptText="Semua Kategori"
                                  style="-fx-font-size: 13;" />
                    </VBox>

                    <!-- [DB] Nilai statis: ≥3.0, ≥3.5, ≥4.0, ≥4.5 -->
                    <VBox spacing="4.0">
                        <Label styleClass="subtitle" text="Rating Minimal" />
                        <ComboBox fx:id="ratingFilter" prefWidth="180.0"
                                  promptText="Semua Rating"
                                  style="-fx-font-size: 13;" />
                    </VBox>

                    <!-- [DB] Range harga statis, filter di query backend -->
                    <VBox spacing="4.0">
                        <Label styleClass="subtitle" text="Rentang Harga" />
                        <ComboBox fx:id="hargaFilter" prefWidth="200.0"
                                  promptText="Semua Harga"
                                  style="-fx-font-size: 13;" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <!-- [CONTROLLER] onAction "#handleResetFilter" -->
                    <Button styleClass="secondary"
                            fx:id="resetFilterButton"
                            style="-fx-padding: 10 22; -fx-font-size: 13;"
                            text="Reset" onAction="#handleResetFilter" />
                </HBox>

                <!-- ================================================
                     TOP DESTINATION SECTION
                     ================================================ -->
                <VBox spacing="15.0" style="-fx-padding: 40 40 20 40;">
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <Label styleClass="header" text="Top Destination" />
                        <Region HBox.hgrow="ALWAYS" />
                        <!-- [CONTROLLER] onAction "#handleLihatSemua" -->
                        <Button styleClass="secondary"
                                style="-fx-padding: 8 20; -fx-font-size: 12;"
                                text="Lihat Semua →" onAction="#handleLihatSemua" />
                    </HBox>
                    <Label styleClass="subtitle"
                           text="Destinasi paling populer dan direkomendasikan untuk kamu" />

                    <!-- ============================================
                         DESTINATION CARDS — FlowPane
                         [DB] Diisi programatik oleh HomeController.loadDestinations()
                              Setiap card: VBox(styleClass=destination-card)
                              Data query: SELECT id, nama, lokasi, harga, rating, gambar_url
                                          FROM destinasi ORDER BY rating DESC LIMIT 12
                         ============================================ -->
                    <FlowPane
                        fx:id="destinationFlowPane"
                        hgap="22.0"
                        vgap="22.0"
                        prefWrapLength="1300.0"
                        style="-fx-padding: 10 0;">

                        <!--
                        ====  TEMPLATE CARD (Satu card per destinasi) ====
                        Hasil query database di-render menjadi card berikut:

                        <VBox styleClass="destination-card" prefWidth="290.0">
                            <ImageView fx:id="cardImage"
                                       fitHeight="180.0" fitWidth="290.0"
                                       preserveRatio="false"
                                       style="-fx-border-radius: 15 15 0 0;
                                              -fx-background-radius: 15 15 0 0;" />
                            <VBox spacing="10.0" style="-fx-padding: 14 15 16 15;">
                                <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                              -fx-text-fill: #f5f5f5;"
                                       text="{destinasi.nama}" wrapText="true" />
                                <Label styleClass="subtitle"
                                       text="📍 {destinasi.lokasi}" />
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <Label styleClass="rating-badge"
                                           text="⭐ {destinasi.rating}" />
                                    <Label styleClass="subtitle"
                                           text="({destinasi.jumlahUlasan} ulasan)" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label styleClass="price-tag"
                                           text="Rp {destinasi.harga}" />
                                </HBox>
                                <Button style="-fx-padding: 9 15; -fx-font-size: 12;
                                               -fx-border-radius: 10; -fx-background-radius: 10;"
                                        text="Lihat Detail →"
                                        onAction="#handleLihatDetail" />
                            </VBox>
                        </VBox>
                        -->

                        <!-- PLACEHOLDER: Ditampilkan saat data belum dimuat -->
                        <VBox alignment="CENTER" spacing="12.0"
                              style="-fx-padding: 40 0;">
                            <Label styleClass="subtitle"
                                   text="Memuat destinasi wisata..." />
                        </VBox>

                    </FlowPane>
                </VBox>

                <!-- ================================================
                     KATEGORI POPULER SECTION
                     ================================================ -->
                <VBox spacing="15.0"
                      style="-fx-padding: 20 40 40 40; -fx-background-color: #161616;">
                    <Label styleClass="header" text="Jelajahi Kategori" />
                    <Label styleClass="subtitle"
                           text="Temukan tempat wisata sesuai selera perjalananmu" />

                    <!-- [DB] Kategori dari SELECT DISTINCT kategori, COUNT(*) FROM destinasi GROUP BY kategori -->
                    <FlowPane fx:id="categoryFlowPane"
                              hgap="14.0" vgap="14.0"
                              prefWrapLength="1300.0"
                              style="-fx-padding: 10 0;">
                        <Button styleClass="category-chip" text="Pantai &amp; Laut" />
                        <Button styleClass="category-chip" text="Pegunungan" />
                        <Button styleClass="category-chip" text="Budaya &amp; Sejarah" />
                        <Button styleClass="category-chip" text="Alam Terbuka" />
                        <Button styleClass="category-chip" text="Taman Hiburan" />
                        <Button styleClass="category-chip" text="Wisata Kuliner" />
                        <Button styleClass="category-chip" text="Belanja" />
                        <Button styleClass="category-chip" text="Olahraga Air" />
                    </FlowPane>
                </VBox>

                <!-- ================================================
                     SPACER
                     ================================================ -->
                <Region style="-fx-min-height: 50;" />
            </VBox>
        </ScrollPane>
    </center>

    <!-- ============================================================
         BOTTOM: FOOTER
         ============================================================ -->
    <bottom>
        <VBox spacing="10.0"
              style="-fx-padding: 25 40; -fx-background-color: #111111;
                     -fx-border-color: #222222; -fx-border-width: 1 0 0 0;">
            <HBox alignment="CENTER_LEFT" spacing="60.0">
                <VBox spacing="8.0">
                    <Label style="-fx-font-size: 16; -fx-font-weight: bold;
                                  -fx-text-fill: #DEFF9A;" text="WISATA" />
                    <Label styleClass="subtitle" text="Sistem Informasi Wisata Indonesia" />
                    <Label styleClass="subtitle" text="Kelompok B6" />
                </VBox>

                <VBox spacing="8.0">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #DEFF9A;"
                           text="Menu" />
                    <Label styleClass="subtitle" text="Home" />
                    <Label styleClass="subtitle" text="Booking Saya" />
                    <Label styleClass="subtitle" text="Itinerary" />
                </VBox>

                <VBox spacing="8.0">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #DEFF9A;"
                           text="Kontak" />
                    <Label styleClass="subtitle" text="b6@wisata.id" />
                    <Label styleClass="subtitle" text="+62 812-3456-7890" />
                    <Label styleClass="subtitle" text="www.wisata-b6.id" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER_RIGHT" spacing="8.0">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #DEFF9A;"
                           text="Follow Us" />
                    <HBox spacing="8.0">
                        <Button styleClass="secondary"
                                style="-fx-padding: 7 14; -fx-font-size: 11;"
                                text="Facebook" />
                        <Button styleClass="secondary"
                                style="-fx-padding: 7 14; -fx-font-size: 11;"
                                text="Instagram" />
                    </HBox>
                </VBox>
            </HBox>

            <Separator />
            <Label alignment="CENTER"
                   style="-fx-text-fill: #555555; -fx-font-size: 11;"
                   text="© 2024 Sistem Informasi Wisata — Kelompok B6. All Rights Reserved."
                   wrapText="true" />
        </VBox>
    </bottom>

</BorderPane>
