<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1280.0"
            styleClass="root"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.PengelolaDashboardController">

    <!-- ╔══════════════════════════════════════╗
         ║           SIDEBAR KIRI               ║
         ╚══════════════════════════════════════╝ -->
    <left>
        <VBox prefWidth="230.0" style="-fx-background-color: #1e293b; -fx-padding: 0;">

            <!-- Logo -->
            <VBox style="-fx-background-color: #0f172a; -fx-padding: 26 22 22 22;">
                <Label text="🗺  WisataApp"
                       style="-fx-font-size: 19; -fx-font-weight: bold; -fx-text-fill: #38bdf8;"/>
                <Label text="Portal Pengelola"
                       style="-fx-font-size: 11; -fx-text-fill: #475569; -fx-padding: 3 0 0 2;"/>
            </VBox>

            <!-- Info User -->
            <VBox style="-fx-background-color: #162032; -fx-padding: 14 18; -fx-border-color: #334155; -fx-border-width: 1 0;">
                <Label text="👤  Pengelola"
                       style="-fx-font-size: 10; -fx-text-fill: #475569;"/>
                <Label fx:id="welcomeLabel" text="Selamat Datang"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #e2e8f0; -fx-wrap-text: true; -fx-padding: 2 0 0 0;"/>
            </VBox>

            <!-- Label seksi nav -->
            <Label text="  MENU"
                   style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-padding: 18 14 6 14;"/>

            <!-- Nav Aktif -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #1d4ed8; -fx-padding: 12 18; -fx-cursor: hand;">
                <Label text="📋" style="-fx-font-size: 14;"/>
                <Label text="Manajemen Destinasi"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>

            <!-- Logout -->
            <Button text="🚪  Keluar" onAction="#handleLogout" maxWidth="Infinity"
                    style="-fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 13 18;
                           -fx-background-color: transparent; -fx-text-fill: #f87171;
                           -fx-cursor: hand; -fx-alignment: CENTER_LEFT;
                           -fx-border-color: transparent; -fx-background-radius: 0;"/>
        </VBox>
    </left>

    <!-- ╔══════════════════════════════════════╗
         ║           KONTEN UTAMA               ║
         ╚══════════════════════════════════════╝ -->
    <center>
        <VBox style="-fx-background-color: #0f172a;">

            <!-- Top bar -->
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-padding: 16 24; -fx-background-color: #1e293b;
                         -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">
                <VBox spacing="2">
                    <Label text="Manajemen Destinasi Wisata"
                           style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
                    <Label text="Tambah, ubah, dan hapus data destinasi wisata"
                           style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Search -->
                <TextField fx:id="searchField" prefWidth="230.0" promptText="🔍  Cari destinasi..."
                           style="-fx-font-size: 13; -fx-padding: 9 14;
                                  -fx-background-color: #0f172a; -fx-text-fill: #e2e8f0;
                                  -fx-prompt-text-fill: #475569;
                                  -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <ComboBox fx:id="kategoriFilter" prefWidth="155.0" promptText="Semua Kategori"/>
            </HBox>

            <!-- Body: Tabel + Form -->
            <HBox spacing="16" VBox.vgrow="ALWAYS" style="-fx-padding: 20;">

                <!-- ── TABEL ── -->
                <VBox spacing="0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1e293b; -fx-background-radius: 10;
                             -fx-border-color: #334155; -fx-border-radius: 10; -fx-border-width: 1;">

                    <!-- Header tabel -->
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-padding: 14 18; -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">
                        <Label text="📋  Daftar Destinasi"
                               style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #cbd5e1;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Klik baris untuk edit →"
                               style="-fx-font-size: 11; -fx-text-fill: #475569;"/>
                    </HBox>

                    <TableView fx:id="destinationTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="idColumn"       prefWidth="50"  text="ID"/>
                            <TableColumn fx:id="namaColumn"     prefWidth="230" text="Nama Destinasi"/>
                            <TableColumn fx:id="kategoriColumn" prefWidth="130" text="Kategori"/>
                            <TableColumn fx:id="hargaColumn"    prefWidth="120" text="Harga (Rp)"/>
                            <TableColumn fx:id="ratingColumn"   prefWidth="80"  text="⭐ Rating"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- ── FORM PANEL ── -->
                <VBox spacing="12" prefWidth="300.0"
                      style="-fx-background-color: #1e293b; -fx-background-radius: 10;
                             -fx-border-color: #334155; -fx-border-radius: 10; -fx-border-width: 1;
                             -fx-padding: 18;">

                    <Label text="✏️  Form Destinasi"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
                    <Separator/>

                    <!-- Nama -->
                    <VBox spacing="4">
                        <Label text="Nama Destinasi"
                               style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                        <TextField fx:id="formNama" promptText="Nama tempat wisata..."/>
                    </VBox>

                    <!-- Kategori -->
                    <VBox spacing="4">
                        <Label text="Kategori"
                               style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                        <ComboBox fx:id="formKategori" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Harga & Rating -->
                    <HBox spacing="10">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Harga (Rp)"
                                   style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                            <TextField fx:id="formHarga" promptText="50000"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Rating"
                                   style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                            <TextField fx:id="formRating" promptText="4.5"/>
                        </VBox>
                    </HBox>

                    <!-- Lokasi -->
                    <VBox spacing="4">
                        <Label text="Lokasi"
                               style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                        <TextField fx:id="formLokasi" promptText="Kota / Provinsi"/>
                    </VBox>

                    <!-- Deskripsi -->
                    <VBox spacing="4" VBox.vgrow="ALWAYS">
                        <Label text="Deskripsi"
                               style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                        <TextArea fx:id="formDeskripsi" prefHeight="90" wrapText="true"
                                  promptText="Deskripsi singkat tentang tempat ini..."/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>

                    <!-- Tombol Aksi -->
                    <HBox spacing="8">
                        <Button fx:id="btnSimpan" text="＋ Simpan" onAction="#handleSimpan"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #22c55e; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 9; -fx-background-radius: 8;
                                       -fx-cursor: hand; -fx-border-color: transparent;"/>
                        <Button fx:id="btnUpdate" text="✎ Ubah" onAction="#handleUpdate"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 9; -fx-background-radius: 8;
                                       -fx-cursor: hand; -fx-border-color: transparent;"/>
                        <Button fx:id="btnHapus" text="✕ Hapus" onAction="#handleHapus"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 9; -fx-background-radius: 8;
                                       -fx-cursor: hand; -fx-border-color: transparent;"/>
                    </HBox>
                    <Button text="↺  Bersihkan Form" onAction="#handleClearForm" maxWidth="Infinity"
                            style="-fx-background-color: #334155; -fx-text-fill: #94a3b8;
                                   -fx-padding: 9; -fx-background-radius: 8;
                                   -fx-cursor: hand; -fx-border-color: transparent;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
