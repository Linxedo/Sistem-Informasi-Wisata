<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="1200.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.DashboardController">
    
    <!-- TOP - HEADER -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #0D47A1, #1976D2); -fx-padding: 20; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="30.0">
                <VBox spacing="5.0">
                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;" text="Jelajahi Wisata Indonesia" />
                    <Label fx:id="welcomeLabel" style="-fx-font-size: 14; -fx-text-fill: #E3F2FD;" text="Selamat Datang" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="myItineraryButton" minHeight="40.0" minWidth="140.0" onAction="#handleMyItinerary" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 10; -fx-background-color: #FF9800; -fx-text-fill: #FFFFFF; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.2), 5, 0, 0, 2);" text="Itinerary Saya" />
                <Button fx:id="logoutButton" minHeight="40.0" minWidth="120.0" onAction="#handleLogout" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 10; -fx-background-color: #FF6B6B; -fx-text-fill: #FFFFFF; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.2), 5, 0, 0, 2);" text="Keluar" />
            </HBox>
        </VBox>
    </top>
    
    <!-- CENTER - MAIN CONTENT -->
    <center>
        <HBox spacing="20.0" style="-fx-padding: 20; -fx-background-color: #F5F5F5;">
            
            <!-- LEFT SIDE - TABLE & SEARCH -->
            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                
                <!-- SEARCH & FILTER CARD -->
                <VBox spacing="12.0" style="-fx-padding: 20; -fx-background-color: #FFFFFF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.1), 8, 0, 0, 2);">
                    <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #0D47A1;" text="Cari Destinasi" />
                    
                    <TextField fx:id="searchField" promptText="Cari nama, kategori, atau lokasi destinasi..." style="-fx-font-size: 12; -fx-padding: 12; -fx-background-color: #FAFAFA; -fx-border-color: #DDDDDD; -fx-border-radius: 5; -fx-background-radius: 5;" />
                    
                    <Label style="-fx-font-size: 12; -fx-text-fill: #666666; -fx-font-weight: bold;" text="Filter Kategori:" />
                    <ComboBox fx:id="kategoriFilter" prefWidth="200.0" promptText="Pilih kategori wisata..." style="-fx-font-size: 12; -fx-padding: 10; -fx-background-color: #FAFAFA; -fx-border-color: #DDDDDD; -fx-border-radius: 5;" />
                </VBox>
                
                <!-- TABLE VIEW CARD -->
                <VBox spacing="8.0" VBox.vgrow="ALWAYS" style="-fx-padding: 20; -fx-background-color: #FFFFFF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.1), 8, 0, 0, 2);">
                    <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #0D47A1;" text="Daftar Destinasi Wisata" />
                    <TableView fx:id="destinationTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 11;">
                        <columns>
                            <TableColumn fx:id="idColumn" minWidth="40.0" prefWidth="50.0" text="ID" />
                            <TableColumn fx:id="namaColumn" minWidth="150.0" prefWidth="200.0" text="Nama Destinasi" />
                            <TableColumn fx:id="kategoriColumn" minWidth="100.0" prefWidth="120.0" text="Kategori" />
                            <TableColumn fx:id="hargaColumn" minWidth="80.0" prefWidth="100.0" text="Harga (Rp)" />
                            <TableColumn fx:id="ratingColumn" minWidth="60.0" prefWidth="80.0" text="Rating" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
            
            <!-- RIGHT SIDE - DETAIL VIEW CARD -->
            <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #FFFFFF; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.1), 8, 0, 0, 2);" prefWidth="340.0">
                
                <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0D47A1;" text="Detail Destinasi" />
                
                <Separator style="-fx-padding: 5; -fx-border-color: #EEEEEE;" />
                
                <!-- DESCRIPTION -->
                <VBox spacing="8.0">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #0D47A1; -fx-font-weight: bold;" text="Deskripsi:" />
                    <TextArea fx:id="deskripsiArea" prefHeight="120.0" style="-fx-font-size: 11; -fx-padding: 10; -fx-control-inner-background: #FAFAFA; -fx-border-color: #DDDDDD; -fx-border-radius: 5; -fx-background-radius: 5;" wrapText="true" />
                </VBox>
                
                <!-- PRICE -->
                <HBox spacing="10.0" style="-fx-padding: 12; -fx-background-color: #FFF3E0; -fx-border-radius: 5; -fx-background-radius: 5;">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #E65100; -fx-font-weight: bold;" text="Harga:" />
                    <Label fx:id="hargaLabel" style="-fx-font-size: 12; -fx-text-fill: #333333;" text="Harga: -" />
                </HBox>
                
                <!-- RATING -->
                <HBox spacing="10.0" style="-fx-padding: 12; -fx-background-color: #F3E5F5; -fx-border-radius: 5; -fx-background-radius: 5;">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #6A1B9A; -fx-font-weight: bold;" text="Rating:" />
                    <Label fx:id="ratingLabel" style="-fx-font-size: 12; -fx-text-fill: #333333;" text="Rating: -" />
                </HBox>
                
                <!-- LOCATION -->
                <VBox spacing="8.0">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #0D47A1; -fx-font-weight: bold;" text="Lokasi:" />
                    <Label fx:id="lokasiLabel" style="-fx-font-size: 11; -fx-text-fill: #666666;" text="-" wrapText="true" />
                </VBox>
                
                <!-- SPACER -->
                <Region VBox.vgrow="ALWAYS" />
                
                <!-- ADD TO ITINERARY BUTTON -->
                <Button fx:id="addToItineraryButton" minHeight="45.0" minWidth="200.0" onAction="#handleAddToItinerary" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 12; -fx-background-color: #FF9800; -fx-text-fill: #FFFFFF; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.2), 5, 0, 0, 2);" text="Tambah ke Itinerary" />
            </VBox>
        </HBox>
    </center>
</BorderPane>
