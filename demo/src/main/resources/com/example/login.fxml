<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" styleClass="root" stylesheets="@application.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.LoginController">
    <center>
        <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 40;">
            <!-- HEADER TITLE -->
            <Label style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #DEFF9A;" text="Sistem Eksplorasi Wisata" />
            <Label style="-fx-font-size: 14; -fx-text-fill: #DAFFDE;" text="Platform Perencanaan Perjalanan Wisata Indonesia" />
            
            <!-- LOGIN FORM -->
            <VBox spacing="15.0" style="-fx-padding: 30; -fx-border-radius: 10; -fx-border-color: #DEFF9A; -fx-border-width: 2;">
                
                <!-- USERNAME -->
                <VBox spacing="5.0">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #DEFF9A;" text="Username" />
                    <TextField fx:id="usernameField" promptText="Masukkan username Anda" style="-fx-font-size: 14;" />
                </VBox>
                
                <!-- PASSWORD -->
                <VBox spacing="5.0">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #DEFF9A;" text="Password" />
                    <PasswordField fx:id="passwordField" promptText="Masukkan password Anda" style="-fx-font-size: 14;" />
                </VBox>
                
                <!-- ROLE SELECTION -->
                <VBox spacing="5.0">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #DEFF9A;" text="Peran (Role)" />
                    <ComboBox fx:id="roleComboBox" prefWidth="200.0" style="-fx-font-size: 14;" />
                </VBox>
                
                <!-- REMEMBER ME -->
                <CheckBox fx:id="rememberCheckBox" style="-fx-text-fill: #DAFFDE;" text="Ingat saya" />
                
                <!-- LOGIN BUTTON -->
                <Button fx:id="loginButton" minHeight="40.0" minWidth="200.0" onAction="#handleLogin" style="-fx-font-size: 14; -fx-font-weight: bold;" text="LOGIN" />
                
                <!-- STATUS LABEL -->
                <Label fx:id="statusLabel" style="-fx-font-size: 12;" text="" wrapText="true" />
                
            </VBox>
            
            <!-- FOOTER LINKS -->
            <HBox alignment="CENTER" spacing="20.0">
                <Hyperlink fx:id="forgotPasswordLink" style="-fx-text-fill: #DEFF9A; -fx-font-size: 12;" text="Lupa Password?" />
                <Label style="-fx-text-fill: #f5f5f5;" text="|" />
                <Label style="-fx-text-fill: #DAFFDE; -fx-font-size: 12;" text="Kelompok B6" />
            </HBox>
        </VBox>
    </center>
    
    <!-- EXIT BUTTON -->
    <top>
        <HBox alignment="TOP_RIGHT" style="-fx-padding: 10;">
            <Button fx:id="exitButton" minHeight="30.0" minWidth="80.0" onAction="#handleExit" style="-fx-font-size: 12;" text="Exit" />
        </HBox>
    </top>
</BorderPane>
