<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
=================================================================
HALAMAN   : BOOKING TIKET
FILE      : booking.fxml
Controller: com.example.BookingController
Kelompok  : B6

ELEMEN FORM:
  Step 1 — DatePicker  : Tanggal kunjungan
  Step 2 — RadioButton : Tipe tiket (Reguler / VIP / Premium)
  Step 3 — Spinner     : Jumlah tiket (Dewasa / Anak-anak)
  Step 4 — TextField   : Data pemesan (Nama, Email, Telepon)
  Step 5 — TextArea    : Catatan khusus
  Step 6 — RadioButton : Metode pembayaran
  Step 7 — CheckBox    : Persetujuan syarat & ketentuan
  Summary Box (kanan)  : Ringkasan otomatis + total biaya

DATABASE INTEGRATION NOTES:
  - [DB] Tipe tiket & harga: SELECT id, nama, harga FROM jenis_tiket
                              WHERE destinasi_id = ?
  - [DB] Harga anak-anak biasanya 50% dari dewasa (konfigurasi di DB)
  - [DB] Konfirmasi pesanan INSERT INTO booking (user_id, destinasi_id,
         tanggal, tipe_tiket_id, jml_dewasa, jml_anak, total, metode_bayar,
         catatan, status) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 'Pending')
  - [DB] Summary auto-update dipicu oleh listener di BookingController
=================================================================
-->

<BorderPane
    prefHeight="950.0"
    prefWidth="1400.0"
    styleClass="root"
    stylesheets="@style.css"
    xmlns="http://javafx.com/javafx/19"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.BookingController">

    <!-- ============================================================
         TOP: HEADER
         ============================================================ -->
    <top>
        <VBox spacing="6.0"
              style="-fx-padding: 18 40; -fx-background-color: #161616;
                     -fx-border-color: #DEFF9A; -fx-border-width: 0 0 2 0;">
            <HBox alignment="CENTER_LEFT" spacing="16.0">
                <!-- [CONTROLLER] onAction="#handleBack" -->
                <Button styleClass="secondary"
                        style="-fx-padding: 8 16; -fx-font-size: 13;"
                        text="← Kembali" onAction="#handleBack" />
                <Label style="-fx-font-size: 24; -fx-font-weight: bold;
                              -fx-text-fill: #DEFF9A;"
                       text="Pesan Tiket Wisata" />
            </HBox>
            <!-- [DB] Diisi dengan nama destinasi dari parameter navigasi -->
            <Label fx:id="destinasiNameLabel"
                   style="-fx-font-size: 14; -fx-text-fill: #DAFFDE;"
                   text="Nama Destinasi" />
        </VBox>
    </top>

    <!-- ============================================================
         CENTER: FORM + SUMMARY
         ============================================================ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <HBox spacing="28.0" style="-fx-padding: 36 40;">

                <!-- ==========================================
                     KIRI: FORM BOOKING (Multi-Step)
                     ========================================== -->
                <VBox spacing="22.0" HBox.hgrow="ALWAYS">

                    <!-- STEP 1: TANGGAL KUNJUNGAN -->
                    <VBox spacing="14.0" styleClass="card">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label styleClass="step-badge" text="1" />
                            <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                          -fx-text-fill: #DEFF9A;"
                                   text="Pilih Tanggal Kunjungan" />
                        </HBox>
                        <Separator />

                        <VBox spacing="6.0">
                            <Label styleClass="subtitle" text="Tanggal Kunjungan:" />
                            <!-- [DB] minDate = hari ini, maxDate = 6 bulan ke depan -->
                            <!-- [CONTROLLER] listener onChange="#handleTanggalChange" -->
                            <DatePicker fx:id="tanggalKunjunganPicker"
                                        prefWidth="280.0"
                                        style="-fx-font-size: 13;" />
                        </VBox>
                        <Label style="-fx-font-size: 11; -fx-text-fill: #555555;"
                               text="Silakan pilih tanggal minimal H+1 dari hari ini." />
                    </VBox>

                    <!-- STEP 2: TIPE TIKET -->
                    <VBox spacing="14.0" styleClass="card">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label styleClass="step-badge" text="2" />
                            <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                          -fx-text-fill: #DEFF9A;"
                                   text="Pilih Tipe Tiket" />
                        </HBox>
                        <Separator />

                        <!--
                        [DB] Tipe tiket diambil dari:
                             SELECT id, nama, harga, deskripsi FROM jenis_tiket
                             WHERE destinasi_id = ?
                        Jika dinamis, RadioButton di-generate di BookingController.
                        -->
                        <VBox spacing="10.0">
                            <HBox spacing="15.0" alignment="CENTER_LEFT"
                                  style="-fx-padding: 12; -fx-background-color: #222222;
                                         -fx-border-radius: 10; -fx-background-radius: 10;">
                                <RadioButton fx:id="regulerRadio" selected="true"
                                             style="-fx-font-size: 13; -fx-font-weight: bold;">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="tipeTicketGroup" />
                                    </toggleGroup>
                                </RadioButton>
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 13; -fx-font-weight: bold;
                                                  -fx-text-fill: #f5f5f5;"
                                           text="Tiket Reguler" />
                                    <Label styleClass="subtitle"
                                           text="Akses area umum destinasi" />
                                </VBox>
                                <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                              -fx-text-fill: #DEFF9A;"
                                       text="Rp 50.000" />
                            </HBox>

                            <HBox spacing="15.0" alignment="CENTER_LEFT"
                                  style="-fx-padding: 12; -fx-background-color: #222222;
                                         -fx-border-radius: 10; -fx-background-radius: 10;">
                                <RadioButton fx:id="vipRadio"
                                             toggleGroup="$tipeTicketGroup"
                                             style="-fx-font-size: 13; -fx-font-weight: bold;" />
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 13; -fx-font-weight: bold;
                                                  -fx-text-fill: #f5f5f5;"
                                           text="Tiket VIP" />
                                    <Label styleClass="subtitle"
                                           text="Akses prioritas + parkir khusus" />
                                </VBox>
                                <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                              -fx-text-fill: #DEFF9A;"
                                       text="Rp 100.000" />
                            </HBox>

                            <HBox spacing="15.0" alignment="CENTER_LEFT"
                                  style="-fx-padding: 12; -fx-background-color: #222222;
                                         -fx-border-radius: 10; -fx-background-radius: 10;">
                                <RadioButton fx:id="premiumRadio"
                                             toggleGroup="$tipeTicketGroup"
                                             style="-fx-font-size: 13; -fx-font-weight: bold;" />
                                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 13; -fx-font-weight: bold;
                                                  -fx-text-fill: #f5f5f5;"
                                           text="Tiket Premium + Tour Guide" />
                                    <Label styleClass="subtitle"
                                           text="VIP + pemandu wisata profesional" />
                                </VBox>
                                <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                              -fx-text-fill: #DEFF9A;"
                                       text="Rp 150.000" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- STEP 3: JUMLAH TIKET -->
                    <VBox spacing="14.0" styleClass="card">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label styleClass="step-badge" text="3" />
                            <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                          -fx-text-fill: #DEFF9A;"
                                   text="Jumlah Tiket" />
                        </HBox>
                        <Separator />

                        <HBox spacing="40.0">
                            <VBox spacing="8.0" prefWidth="200.0">
                                <Label styleClass="subtitle" text="Dewasa (≥13 tahun):" />
                                <!--
                                [CONTROLLER] listener onChange untuk update summary total
                                [DB] min=1, max dikonfigurasi dari destinasi.maks_pengunjung
                                -->
                                <Spinner fx:id="jumlahDewasaSpinner"
                                         initialValue="1" min="1" max="20"
                                         prefWidth="160.0"
                                         style="-fx-font-size: 13;" />
                            </VBox>
                            <VBox spacing="8.0" prefWidth="200.0">
                                <Label styleClass="subtitle" text="Anak-anak (≤12 tahun):" />
                                <!-- [DB] Harga anak = 50% dari harga dewasa -->
                                <Spinner fx:id="jumlahAnakSpinner"
                                         initialValue="0" min="0" max="20"
                                         prefWidth="160.0"
                                         style="-fx-font-size: 13;" />
                            </VBox>
                        </HBox>
                        <Label style="-fx-font-size: 11; -fx-text-fill: #555555;"
                               text="Harga anak-anak (≤12 thn) = 50% dari harga dewasa." />
                    </VBox>

                    <!-- STEP 4: DATA PEMESAN -->
                    <VBox spacing="14.0" styleClass="card">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label styleClass="step-badge" text="4" />
                            <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                          -fx-text-fill: #DEFF9A;"
                                   text="Data Pemesan" />
                        </HBox>
                        <Separator />

                        <!-- [DB] Jika user sudah login, isi otomatis dari users.nama, users.email -->
                        <HBox spacing="20.0">
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="subtitle" text="Nama Lengkap *" />
                                <TextField fx:id="namaTextField"
                                           promptText="Masukkan nama lengkap..."
                                           style="-fx-font-size: 13;" />
                            </VBox>
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="subtitle" text="Email *" />
                                <TextField fx:id="emailTextField"
                                           promptText="nama@email.com"
                                           style="-fx-font-size: 13;" />
                            </VBox>
                        </HBox>

                        <VBox spacing="6.0">
                            <Label styleClass="subtitle" text="Nomor Telepon *" />
                            <TextField fx:id="teleponTextField"
                                       prefWidth="280.0"
                                       promptText="+62 ..."
                                       style="-fx-font-size: 13;" />
                        </VBox>

                        <VBox spacing="6.0">
                            <Label styleClass="subtitle" text="Catatan Khusus (opsional)" />
                            <TextArea fx:id="catatanTextArea"
                                      prefHeight="82.0"
                                      promptText="Contoh: butuh kursi roda, alergi makanan tertentu, dll."
                                      style="-fx-control-inner-background: #1a1a1a;
                                             -fx-text-fill: #DAFFDE; -fx-font-size: 13;
                                             -fx-padding: 12; -fx-border-radius: 10;
                                             -fx-background-radius: 10; -fx-border-color: #2e2e2e;"
                                      wrapText="true" />
                        </VBox>
                    </VBox>

                    <!-- STEP 5: METODE PEMBAYARAN -->
                    <VBox spacing="14.0" styleClass="card">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label styleClass="step-badge" text="5" />
                            <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                          -fx-text-fill: #DEFF9A;"
                                   text="Metode Pembayaran" />
                        </HBox>
                        <Separator />

                        <VBox spacing="10.0">
                            <RadioButton fx:id="tunaiRadio" selected="true"
                                         style="-fx-font-size: 13;"
                                         text="Tunai di Lokasi">
                                <toggleGroup>
                                    <ToggleGroup fx:id="paymentMethodGroup" />
                                </toggleGroup>
                            </RadioButton>
                            <RadioButton fx:id="transferRadio"
                                         toggleGroup="$paymentMethodGroup"
                                         style="-fx-font-size: 13;"
                                         text="Transfer Bank (BCA / Mandiri / BRI)" />
                            <RadioButton fx:id="eWalletRadio"
                                         toggleGroup="$paymentMethodGroup"
                                         style="-fx-font-size: 13;"
                                         text="E-Wallet (GoPay / OVO / Dana)" />
                        </VBox>
                    </VBox>

                    <!-- STEP 6: SYARAT & KETENTUAN -->
                    <VBox spacing="14.0" styleClass="card">
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label styleClass="step-badge" text="6" />
                            <Label style="-fx-font-size: 15; -fx-font-weight: bold;
                                          -fx-text-fill: #DEFF9A;"
                                   text="Persetujuan" />
                        </HBox>
                        <Separator />

                        <CheckBox fx:id="agreementCheckBox"
                                  text="Saya setuju dengan Syarat &amp; Ketentuan yang berlaku"
                                  style="-fx-font-size: 13;" />
                        <CheckBox fx:id="privacyCheckBox"
                                  text="Saya menyetujui Kebijakan Privasi kami"
                                  style="-fx-font-size: 13;" />
                    </VBox>

                </VBox>

                <!-- ==========================================
                     KANAN: SUMMARY BOX (Sticky-like)
                     ========================================== -->
                <VBox spacing="18.0" prefWidth="360.0">

                    <!-- RINGKASAN PESANAN -->
                    <!--
                    [CONTROLLER] Panel ini di-update secara real-time oleh listener:
                    - tanggalKunjunganPicker.valueProperty().addListener(...)
                    - tipeTicketGroup.selectedToggleProperty().addListener(...)
                    - jumlahDewasaSpinner.valueProperty().addListener(...)
                    - jumlahAnakSpinner.valueProperty().addListener(...)
                    -->
                    <VBox spacing="14.0" styleClass="card"
                          style="-fx-background-color: #1e1e1e;
                                 -fx-border-color: #DEFF9A; -fx-border-width: 1.5;
                                 -fx-border-radius: 15; -fx-background-radius: 15;">
                        <Label style="-fx-font-size: 16; -fx-font-weight: bold;
                                      -fx-text-fill: #DEFF9A;"
                               text="Ringkasan Pesanan" />
                        <Separator />

                        <!-- DESTINASI -->
                        <HBox spacing="8.0">
                            <Label style="-fx-font-size: 12; -fx-text-fill: #777777;"
                                   text="Destinasi" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="summaryDestinasiLabel"
                                   style="-fx-font-size: 12; -fx-font-weight: bold;
                                          -fx-text-fill: #f5f5f5; -fx-text-alignment: right;"
                                   text="—" wrapText="true" />
                        </HBox>

                        <!-- TANGGAL -->
                        <HBox spacing="8.0">
                            <Label style="-fx-font-size: 12; -fx-text-fill: #777777;"
                                   text="Tanggal" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="summaryTanggalLabel"
                                   style="-fx-font-size: 12; -fx-font-weight: bold;
                                          -fx-text-fill: #f5f5f5;"
                                   text="Pilih tanggal" />
                        </HBox>

                        <!-- TIPE TIKET -->
                        <HBox spacing="8.0">
                            <Label style="-fx-font-size: 12; -fx-text-fill: #777777;"
                                   text="Tipe Tiket" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="summaryTipeTicketLabel"
                                   style="-fx-font-size: 12; -fx-font-weight: bold;
                                          -fx-text-fill: #f5f5f5;"
                                   text="Reguler" />
                        </HBox>

                        <!-- JUMLAH DEWASA -->
                        <HBox spacing="8.0">
                            <Label style="-fx-font-size: 12; -fx-text-fill: #777777;"
                                   text="Dewasa × Rp 50.000" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="summaryDewasaLabel"
                                   style="-fx-font-size: 12; -fx-font-weight: bold;
                                          -fx-text-fill: #f5f5f5;"
                                   text="Rp 50.000" />
                        </HBox>

                        <!-- JUMLAH ANAK -->
                        <HBox spacing="8.0">
                            <Label style="-fx-font-size: 12; -fx-text-fill: #777777;"
                                   text="Anak-anak × Rp 25.000" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="summaryAnakLabel"
                                   style="-fx-font-size: 12; -fx-font-weight: bold;
                                          -fx-text-fill: #f5f5f5;"
                                   text="Rp 0" />
                        </HBox>

                        <Separator />

                        <!-- TOTAL -->
                        <HBox spacing="8.0">
                            <Label style="-fx-font-size: 14; -fx-font-weight: bold;
                                          -fx-text-fill: #DAFFDE;"
                                   text="Total Biaya" />
                            <Region HBox.hgrow="ALWAYS" />
                            <!-- [CONTROLLER] Auto-hitung: (jml_dewasa * harga) + (jml_anak * harga*0.5) -->
                            <Label fx:id="totalHargaLabel"
                                   style="-fx-font-size: 22; -fx-font-weight: bold;
                                          -fx-text-fill: #DEFF9A;"
                                   text="Rp 50.000" />
                        </HBox>

                        <Label style="-fx-font-size: 10; -fx-text-fill: #555555;
                                      -fx-font-style: italic;"
                               text="✓ Harga sudah termasuk pajak &amp; retribusi"
                               wrapText="true" />
                    </VBox>

                    <!-- KONFIRMASI TOMBOL -->
                    <VBox spacing="10.0">
                        <!-- [CONTROLLER] onAction="#handleKonfirmasi" — validasi form dulu -->
                        <!-- [DB] INSERT INTO booking (...) VALUES (...) pada sukses validasi -->
                        <Button fx:id="konfirmasiButton"
                                minHeight="52.0"
                                style="-fx-padding: 14 30; -fx-font-size: 15;
                                       -fx-font-weight: bold; -fx-background-color: #DEFF9A;
                                       -fx-text-fill: #121212; -fx-border-radius: 15;
                                       -fx-background-radius: 15;"
                                text="Konfirmasi Pesanan" onAction="#handleKonfirmasi" />
                        <Button styleClass="secondary"
                                minHeight="42.0"
                                style="-fx-padding: 10 20; -fx-font-size: 13;"
                                text="← Kembali" onAction="#handleBack" />
                    </VBox>

                    <!-- NOTES -->
                    <VBox spacing="6.0" styleClass="card"
                          style="-fx-background-color: rgba(222,255,154,0.05);
                                 -fx-border-color: rgba(222,255,154,0.2); -fx-border-width: 1;
                                 -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 14;">
                        <Label style="-fx-font-size: 12; -fx-font-weight: bold;
                                      -fx-text-fill: #DEFF9A;" text="Informasi Penting" />
                        <Label style="-fx-font-size: 11; -fx-text-fill: #888888;"
                               text="• E-tiket akan dikirim ke email Anda"
                               wrapText="true" />
                        <Label style="-fx-font-size: 11; -fx-text-fill: #888888;"
                               text="• Pembatalan &gt; 24 jam sebelum kunjungan mendapat refund"
                               wrapText="true" />
                        <Label style="-fx-font-size: 11; -fx-text-fill: #888888;"
                               text="• Tunjukkan e-tiket saat masuk ke destinasi"
                               wrapText="true" />
                    </VBox>

                </VBox>

            </HBox>
        </ScrollPane>
    </center>

</BorderPane>
